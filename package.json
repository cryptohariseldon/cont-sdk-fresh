{
  "name": "@fermilabs/continuum-sdk",
  "version": "0.1.0",
  "private": true,
  "description": "Self-contained SDK for Mango relayer quoting, Continuum harness reads, and direct chain interactions.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "continuum-quoter": "./dist/bin/run-quoter.js",
    "continuum-create-mango-account": "./dist/bin/create-mango-account.js",
    "continuum-deposit-usdc": "./dist/bin/deposit-usdc.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "create-mango-account": "ts-node src/bin/create-mango-account.ts",
    "deposit-usdc": "ts-node src/bin/deposit-usdc.ts"
  },
  "dependencies": {
    "@blockworks-foundation/mango-v4": "^0.24.0",
    "@blockworks-foundation/mango-v4-settings": "^0.14.24",
    "@blockworks-foundation/mangolana": "^0.0.17",
    "@coral-xyz/anchor": "^0.29.0",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@iarna/toml": "^2.2.5",
    "@openbook-dex/openbook-v2": "^0.2.10",
    "@project-serum/serum": "^0.13.65",
    "@pythnetwork/client": "^2.22.1",
    "@solana/spl-token": "^0.3.7",
    "@solana/web3.js": "^1.78.2",
    "@switchboard-xyz/on-demand": "^3.9.0",
    "@switchboard-xyz/sbv2-lite": "^0.2.4",
    "big.js": "^7.0.1",
    "bs58": "^6.0.0",
    "cross-fetch": "^4.1.0",
    "dotenv": "^16.0.3",
    "fast-copy": "^4.0.2",
    "lodash": "^4.18.1",
    "switchboard-anchor": "npm:@coral-xyz/anchor@^0.30.1"
  },
  "devDependencies": {
    "@types/node": "^18.11.18",
    "ts-node": "^10.9.1",
    "typescript": "^5.6.3"
  }
}
